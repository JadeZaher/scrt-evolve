# Rust build artifacts
/target/

# Backtrace / debug
*.pdb

# Environment
.env
.env.local

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# OMC orchestration scratch state
.omc/

# scrt mind-palace working memory (local scratch, not a project artifact)
.mpg/

# Conductor session scratch log
conductor/.conductor_session_log

# Python bytecode caches + packaging build artifacts (track 28: the package is
# pip/uv-installed from pyproject.toml; build/ and *.egg-info/ are regenerated).
__pycache__/
*.pyc
python/build/
*.egg-info/

# Scratch run dirs keep their config but ignore artifacts (see run-*/.gitignore);
# belt-and-suspenders for any model weights / datasets that land at the root.
*.safetensors
*.gguf

# Bench: keep the scaffold (evolve.toml, RUNBOOK.md, harvest script) but NEVER
# commit the adapted corpus (personal Claude Code transcripts — privacy, spec
# §Constraints "no transcript leaves the machine") or the work/ artifacts.
bench/corpus/
bench/work/
bench/.mpg/
bench/traces/

# Bench: run logs are one-off validation scratch — never commit them.
bench/**/*.log

# Demo: scratch output dir written by demo/evolve.toml's work_dir (datasets,
# discovered.json, plan.json, .bak) — regenerated on each run, never commit.
demo/work/
